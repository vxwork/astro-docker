# GitHub Container Registry Configuration Example
# Copy this file to .env and fill in actual values

# Registry configuration (usually no need to modify)
REGISTRY=ghcr.io

# GitHub username or organization name (automatically fetched from git remote if not set)
REPO_OWNER=your-github-username

# Repository name (automatically fetched from git remote if not set)
REPO_NAME=astro-docker

# Image tag (specified during deployment or auto-fetched by script)
# IMAGE_TAG=abc12345

# GHCR login credentials (used by deploy.sh script for automatic login)
# GHCR_USERNAME=your-github-username
# GHCR_TOKEN=your-github-personal-access-token

# GitHub Container Registry 配置示例
# 复制此文件为 .env 并填入实际值

# Registry 配置 (通常不需要修改)
REGISTRY=ghcr.io

# GitHub 用户名或组织名 (会自动从 git remote 获取，如果没有设置则使用此值)
REPO_OWNER=your-github-username

# 仓库名称 (会自动从 git remote 获取，如果没有设置则使用此值)
REPO_NAME=astro-docker

# 镜像标签 (部署时指定，或使用脚本自动获取)
# IMAGE_TAG=abc12345

# GHCR 登录凭证 (用于 deploy.sh 脚本自动登录)
# GHCR_USERNAME=your-github-username
# GHCR_TOKEN=your-github-personal-access-token

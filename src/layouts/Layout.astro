---
const { title = "我的博客" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
  <!-- 顶部导航栏 -->
  <nav class="bg-white shadow border-b sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href="/" class="text-2xl font-bold text-gray-900">我的博客</a>
      
      <div class="flex items-center gap-8 text-sm">
        <a href="/blog" class="hover:text-blue-600 transition">博客</a>
        <a href="/admin" class="hover:text-blue-600 transition">管理后台</a>
      </div>
    </div>
  </nav>

  <main class="min-h-[calc(100vh-73px)]">
    <slot />
  </main>

  <footer class="bg-white border-t py-12 mt-20">
    <div class="max-w-6xl mx-auto px-6 text-center text-gray-500">
      © 2026 我的博客 | Powered by Astro + SQLite + Docker
    </div>
  </footer>
</body>
</html>
---
// src/pages/blog/[slug].astro
import { getPostBySlug } from '../../db/index.js';
import Layout from '../../layouts/Layout.astro';

const { slug } = Astro.params;

// 使用纯 SQL 获取文章
const post = getPostBySlug(slug);

if (!post) {
  return Astro.redirect('/404');
}
---

<Layout title={post.title}>
  <article>
    <header>
      <h1>{post.title}</h1>
      <p>
        作者：{post.author} | 
        发布时间：{new Date(post.publishedAt).toLocaleDateString()}
      </p>
    </header>

    <div class="prose" set:html={post.content} />
  </article>
</Layout>

<style>
  .prose {
    max-width: 65ch;
    margin: 2rem auto;
    line-height: 1.7;
  }
</style>
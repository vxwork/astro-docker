---
import Layout from '../layouts/Layout.astro';
import { getAllPosts } from '../db/index.js';

const allPosts = getAllPosts();
const latestPosts = allPosts.slice(0, 6); // 显示最新6篇文章
---

<Layout title="我的博客 - 首页">
  <!-- Hero 区域 -->
  <div class="bg-gradient-to-br from-blue-600 to-indigo-700 text-white py-24">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h1 class="text-5xl md:text-6xl font-bold mb-6">
        欢迎来到我的博客
      </h1>
      <p class="text-xl md:text-2xl mb-10 max-w-2xl mx-auto opacity-90">
        记录技术思考、学习笔记与生活感悟
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/blog" 
           class="bg-white text-blue-700 px-8 py-4 rounded-full font-semibold text-lg hover:bg-gray-100 transition">
          浏览所有文章
        </a>
        <a href="/admin" 
           class="border border-white text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-white/10 transition">
          进入管理后台
        </a>
      </div>
    </div>
  </div>

  <!-- 最新文章 -->
  <div class="max-w-5xl mx-auto px-6 py-16">
    <div class="flex justify-between items-end mb-10">
      <h2 class="text-3xl font-bold">最新文章</h2>
      <a href="/blog" class="text-blue-600 hover:underline flex items-center gap-2">
        查看全部 →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {latestPosts.map((post: any) => (
        <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden hover:shadow-xl transition group">
          <div class="h-48 bg-gray-200 flex items-center justify-center text-gray-400">
            <!-- 可以后续加封面图 -->
            <span class="text-4xl">📝</span>
          </div>
          
          <div class="p-6">
            <h3 class="font-semibold text-xl mb-3 line-clamp-2 group-hover:text-blue-600 transition">
              <a href={`/blog/${post.slug}`}>{post.title}</a>
            </h3>
            
            <p class="text-gray-600 text-sm line-clamp-3 mb-4">
              {post.content ? post.content.replace(/<[^>]+>/g, '').slice(0, 120) + '...' : ''}
            </p>

            <div class="flex justify-between items-center text-sm text-gray-500">
              <span>{post.author}</span>
              <span>{new Date(post.publishedAt).toLocaleDateString('zh-CN')}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- 关于我模块 -->
  <div class="bg-gray-50 py-16">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">关于我</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        我是一名热爱技术的开发者，喜欢记录学习过程和思考心得。
        这里会分享前端、后端、DevOps 以及生活中的各种内容。
      </p>
      <div class="mt-10">
        <a href="/about" class="text-blue-600 hover:underline">了解更多关于我 →</a>
      </div>
    </div>
  </div>
</Layout>
---
import Layout from '../../layouts/Layout.astro';
import { db } from '../../db/index.js';

const cookies = Astro.cookies;
const isLoggedIn = cookies.get('admin_logged_in')?.value === 'true';

let allPosts = [];
if (isLoggedIn) {
  allPosts = db.prepare('SELECT slug, title, author FROM posts ORDER BY publishedAt DESC').all();
}
---

<Layout title="管理后台">
  <div style="max-width: 900px; margin: 40px auto; padding: 20px; font-family: system-ui;">
    <h1 style="font-size: 28px; margin-bottom: 30px;">管理后台</h1>

    {isLoggedIn ? (
      <div>
        <p style="color: green; margin-bottom: 20px;">✅ 已登录</p>
        <p>当前共有 {allPosts.length} 篇文章</p>
        <a href="/admin/new" style="background: #2563eb; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none;">新建文章</a>
        <a href="/admin/logout" style="margin-left: 15px; color: red;">退出登录</a>
      </div>
    ) : (
      <div style="background: white; padding: 40px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); max-width: 400px;">
        <h2 style="text-align: center; margin-bottom: 30px;">后台登录</h2>
        
        <form method="POST" action="/api/admin/login">
          <p><input type="text" name="username" placeholder="用户名" value="admin" 
             style="width: 100%; padding: 12px; margin-bottom: 15px; border: 1px solid #ccc; border-radius: 6px;" /></p>
          
          <p><input type="password" name="password" placeholder="密码" value="admin123" 
             style="width: 100%; padding: 12px; margin-bottom: 20px; border: 1px solid #ccc; border-radius: 6px;" /></p>
          
          <button type="submit" 
            style="width: 100%; padding: 12px; background: #2563eb; color: white; border: none; border-radius: 6px; font-size: 16px;">
            登录
          </button>
        </form>
        
        <p style="text-align: center; margin-top: 15px; color: #666; font-size: 14px;">
          默认账号：admin / admin123
        </p>
      </div>
    )}
  </div>
</Layout>
---
import Layout from '../../layouts/Layout.astro';
import { db } from '../../db/index.js';

const allPosts = db.prepare('SELECT id, slug, title, author FROM posts ORDER BY publishedAt DESC').all();
---

<Layout title="文章管理后台">
  <h1>文章管理后台</h1>
  
  <a href="/admin/new">+ 新建文章</a>
  
  <table border="1" cellpadding="10" style="margin-top: 20px; width: 100%; border-collapse: collapse;">
    <thead>
      <tr>
        <th>标题</th>
        <th>Slug</th>
        <th>作者</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      {allPosts.map((post: any) => (
        <tr>
          <td>{post.title}</td>
          <td>{post.slug}</td>
          <td>{post.author}</td>
          <td>
            <a href={`/admin/edit/${post.slug}`}>编辑</a>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</Layout>
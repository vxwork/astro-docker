---
import Layout from '../../layouts/Layout.astro';
import { db } from '../../db/index.js';

const cookies = Astro.cookies;
const isLoggedIn = cookies.get('admin_logged_in')?.value === 'true';

let allPosts = [];
if (isLoggedIn) {
  allPosts = db.prepare('SELECT slug, title, author FROM posts ORDER BY publishedAt DESC').all();
}
---

<Layout title="管理后台">
  <div style="max-width: 420px; margin: 80px auto; padding: 40px; background: white; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
    {isLoggedIn ? (
      <div>
        <h1 style="text-align:center; margin-bottom:30px;">管理后台</h1>
        <p style="color:green; text-align:center;">✅ 已登录</p>
        <p style="text-align:center; margin:20px 0;">共有 {allPosts.length} 篇文章</p>
        <a href="/admin/new" style="display:block; text-align:center; background:#2563eb; color:white; padding:12px; border-radius:8px; margin:20px 0; text-decoration:none;">新建文章</a>
        <a href="/admin/logout" style="color:red; display:block; text-align:center;">退出登录</a>
      </div>
    ) : (
      <div>
        <h2 style="text-align:center; margin-bottom:30px;">后台登录</h2>
        
        <form id="loginForm">
          <input type="text" id="username" placeholder="用户名" value="admin" 
            style="width:100%; padding:12px; margin-bottom:15px; border:1px solid #ddd; border-radius:6px;" required />
          
          <input type="password" id="password" placeholder="密码" value="admin123" 
            style="width:100%; padding:12px; margin-bottom:20px; border:1px solid #ddd; border-radius:6px;" required />
          
          <button type="submit" 
            style="width:100%; padding:14px; background:#2563eb; color:white; border:none; border-radius:8px; font-size:16px; cursor:pointer;">
            登录
          </button>
        </form>

        <p style="text-align:center; margin-top:20px; color:#666; font-size:14px;">
          默认：admin / admin123
        </p>
      </div>
    )}
  </div>
</Layout>

<script>
  const form = document.getElementById('loginForm');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const username = document.getElementById('username').value;
      const password = document.getElementById('password').value;

      try {
        const res = await fetch('/api/admin/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({ username, password })
        });

        if (res.redirected) {
          window.location.href = res.url;
        } else {
          alert('登录失败：用户名或密码错误');
        }
      } catch (err) {
        alert('网络错误，请稍后重试');
      }
    });
  }
</script>